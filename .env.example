# --- MCP server ---
PORT=3005
# Optional: bind HTTP mode to one interface, for example 127.0.0.1 for local-only access.
# WARDEN_MCP_HOST=127.0.0.1
# Optional: force stdio mode without passing --stdio.
# WARDEN_MCP_STDIO=true
TOOL_PREFIX=keychain
TOOL_SEPARATOR=_
MCP_APP_NAME=keychain-mcp

# Optional: root folder where per-profile bw CLI state is stored (to avoid config/session clashes).
KEYCHAIN_BW_HOME_ROOT=/data/bw-profiles

# When true, block all tools that mutate the vault.
# Read operations and helpers are still allowed.
READONLY=false
# KEYCHAIN_READONLY=false

# When true, force reveal=false for all secret-returning tools.
NOREVEAL=false
# KEYCHAIN_NOREVEAL=false

# Optional: mirror structuredContent into text for clients that ignore structured results.
# KEYCHAIN_TEXT_COMPAT_MODE=structured_json

# Optional: skip the default bw sync before write operations.
KEYCHAIN_SYNC_ON_WRITE=true

# Bitwarden/Vaultwarden config MUST be provided via HTTP headers by default:
# - X-BW-Host
# - X-BW-Password
# - X-BW-ClientId + X-BW-ClientSecret  OR  X-BW-User / X-BW-Username
# - (optional) X-BW-Unlock-Interval
#
# Set KEYCHAIN_ALLOW_ENV_FALLBACK=true only for trusted single-tenant HTTP deployments
# where headerless requests should inherit the server-side BW_* env vars below.
KEYCHAIN_ALLOW_ENV_FALLBACK=false
# BW_HOST=https://vaultwarden.example.com
# BW_PASSWORD=your-master-password
# BW_CLIENTID=user.xxxxx
# BW_CLIENTSECRET=xxxxx
# BW_USER=user@example.com
# BW_USERNAME=user@example.com
# BW_UNLOCK_INTERVAL=300
