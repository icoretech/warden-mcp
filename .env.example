# --- MCP server ---
PORT=3005
TOOL_PREFIX=keychain
MCP_APP_NAME=keychain-mcp

# Optional: root folder where per-profile bw CLI state is stored (to avoid config/session clashes).
KEYCHAIN_BW_HOME_ROOT=/data/bw-profiles

# When true, block all tools that mutate the vault (create/edit/delete/move/restore/attachments).
# Read operations and helpers are still allowed.
READONLY=false

# Bitwarden/Vaultwarden config MUST be provided via HTTP headers:
# - X-BW-Host
# - X-BW-Password
# - X-BW-ClientId + X-BW-ClientSecret  OR  X-BW-User
# - (optional) X-BW-Unlock-Interval
