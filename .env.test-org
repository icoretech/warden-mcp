# Integration test environment for the org-focused compose stack.
#
# This is safe to commit (dev-only local Vaultwarden credentials).

# Use email/password login for the local org test account.
#
# Note: if you previously ran the org stack with a different password for this
# email, login will fail. Bumping the email keeps the bootstrap idempotent.
BW_USER=org-owner-local@example.com
BW_PASSWORD=org-master-password-please-change

# Optional: API-key login (harder to bootstrap), set both:
# BW_CLIENTID=user.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# BW_CLIENTSECRET=REDACTED

# How long to keep bw unlocked between operations
BW_UNLOCK_INTERVAL=60

# Playwright bootstrap configuration
VW_NAME=Warden Org Owner
VW_ORG_NAME=Warden Test Org
VW_BOOTSTRAP_TIMEOUT_MS=15000

# When true, org-focused integration tests should fail (not skip) if no org exists.
KEYCHAIN_REQUIRE_ORG_TESTS=true

# MCP server settings (not strictly needed for integration tests)
PORT=3005
TOOL_PREFIX=keychain
MCP_APP_NAME=warden-mcp
READONLY=false
