FROM node:24-bookworm-slim

# Dev image: Node + Bitwarden CLI.
# Use the npm-distributed CLI for multi-arch compatibility (arm64/amd64).
RUN npm install -g @bitwarden/cli@2026.1.0

# The official node image already includes a `node` user (uid/gid 1000).
RUN mkdir -p /app /data \
  && chown -R node:node /app /data

USER node
WORKDIR /app
ENV HOME=/data
