FROM node:24-bookworm-slim

# Dev image: Node only. The runtime resolves `bw` from the repo-installed
# optional dependency so compose and CI exercise the candidate package version.

# The official node image already includes a `node` user (uid/gid 1000).
RUN mkdir -p /app /data \
  && chown -R node:node /app /data

USER node
WORKDIR /app
ENV HOME=/data
