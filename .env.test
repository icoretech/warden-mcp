# Integration test environment for docker-compose.
#
# This is safe to commit (dev-only local vaultwarden credentials).

# Use email/password login for the local vaultwarden instance.
BW_USER=test@example.com
BW_PASSWORD=test-master-password-please-change

# The compose bootstrap now generates a gitignored shell env file at
# tmp/vaultwarden-bootstrap/apikey.env for API-key smoke tests.
# You can still override those values manually if you want:
# BW_CLIENTID=user.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# BW_CLIENTSECRET=REDACTED

# How long to keep bw unlocked between operations
BW_UNLOCK_INTERVAL=60

# MCP server settings (not strictly needed for integration tests)
PORT=3005
TOOL_PREFIX=keychain
MCP_APP_NAME=warden-mcp
READONLY=false
