{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "enabledManagers": ["custom.regex", "docker-compose", "github-actions", "npm"],
  "dependencyDashboard": true,
  "labels": ["dependencies"],
  "ignoreTests": false,
  "platformAutomerge": false,
  "prHourlyLimit": 0,
  "prConcurrentLimit": 10,
  "rebaseWhen": "conflicted",
  "rangeStrategy": "bump",
  "timezone": "Europe/Rome",
  "lockFileMaintenance": {
    "enabled": true
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^biome\\.json$/"],
      "matchStrings": [
        "\"\\$schema\"\\s*:\\s*\"https://biomejs\\.dev/schemas/(?<currentValue>[^/]+)/schema\\.json\""
      ],
      "depNameTemplate": "@biomejs/biome",
      "datasourceTemplate": "npm",
      "versioningTemplate": "npm"
    },
    {
      "customType": "regex",
      "description": "Track Playwright compose bootstrap images from the npm package version",
      "managerFilePatterns": ["/^docker-compose(\\.org)?\\.yml$/"],
      "matchStrings": [
        "image:\\s+mcr\\.microsoft\\.com/playwright:v(?<currentValue>\\d+\\.\\d+\\.\\d+)-jammy"
      ],
      "depNameTemplate": "playwright",
      "datasourceTemplate": "npm",
      "versioningTemplate": "npm",
      "autoReplaceStringTemplate": "image: mcr.microsoft.com/playwright:v{{{newValue}}}-jammy"
    }
  ],
  "packageRules": [
    {
      "description": "Keep Biome package and schema updates together",
      "matchManagers": ["npm", "custom.regex"],
      "matchPackageNames": ["@biomejs/biome"],
      "groupName": "biome tooling",
      "groupSlug": "biome-tooling"
    },
    {
      "description": "Group TypeScript-related tooling",
      "matchManagers": ["npm"],
      "matchPackageNames": [
        "/^typescript$/",
        "/^tsx$/",
        "/^@types\\/node$/",
        "/^@types\\/express$/"
      ],
      "groupName": "typescript tooling",
      "groupSlug": "typescript-tooling"
    },
    {
      "description": "Keep Playwright package and compose image updates together",
      "matchManagers": ["custom.regex", "npm"],
      "matchPackageNames": ["playwright"],
      "groupName": "playwright tooling",
      "groupSlug": "playwright-tooling"
    },
    {
      "description": "Prevent Docker-only Playwright image updates",
      "matchManagers": ["docker-compose"],
      "matchDatasources": ["docker"],
      "matchPackageNames": ["mcr.microsoft.com/playwright"],
      "enabled": false
    },
    {
      "description": "Group GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "groupName": "github actions",
      "groupSlug": "github-actions"
    },
    {
      "description": "Automerge non-major updates after checks pass",
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Ignore Node.js engine constraint — library supports any Node >=24",
      "matchDepNames": ["node"],
      "enabled": false
    }
  ]
}
